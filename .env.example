# ─────────────────────────────────────────────
# FreelanceRadar — Environment Variables
# Copy this file to .env.local and fill in values
# ─────────────────────────────────────────────

# ── Authentication ──────────────────────────
# When set, the app requires this secret to access the UI and API.
# Leave UNSET for local development (no auth needed).
# For production: generate with: openssl rand -hex 32
APP_SECRET=

# ── AI (Anthropic) ──────────────────────────
# Optional: set here for local use, or enter via the Settings page.
# Users of the deployed app can provide their own key through Settings.
ANTHROPIC_API_KEY=

# ── Freelancer.com ───────────────────────────
# Optional: required only for the Freelancer.com connector.
FREELANCER_API_TOKEN=

# ── Database ─────────────────────────────────
# SQLite path (used by Prisma). Do not commit the .db file.
DATABASE_URL="file:./dev.db"

# ── CORS ─────────────────────────────────────
# Origin allowed to call the API. Defaults to http://localhost:3000.
# In production set to your actual domain: https://radar.yourdomain.com
ALLOWED_ORIGIN=http://localhost:3000

# ── Developer Profile ─────────────────────────
# Overrides the default profile used for AI proposal generation.
# If not set, a generic placeholder is used (safe for public repos).
# DEVELOPER_PROFILE="# Your Name\n\n## Skills\n- TypeScript\n- React\n..."
